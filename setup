#!/usr/bin/env bash

set -Eeuo pipefail

readonly RAW_BASE_URL="https://raw.githubusercontent.com/pervezfunctor/linux-config/refs/heads/main"

main() {
  command -v curl >/dev/null 2>&1 || {
    echo "setup launcher requires curl for remote bootstrap" >&2
    exit 1
  }

  command -v python3 >/dev/null 2>&1 || {
    curl -LsSf https://astral.sh/uv/install.sh | sh
    uv tool install python
    export PATH="$HOME/.local/bin:$PATH"
  }

  command -v python3 >/dev/null 2>&1 || {
    echo "setup launcher requires python3" >&2
    exit 1
  }

  exec bash -c 'curl -fsSL "$1" | python3 - "$@"' bash "${RAW_BASE_URL}/setup.py" "$@"
}

main "$@"
