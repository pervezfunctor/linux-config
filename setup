#!/usr/bin/env bash

set -euo pipefail

readonly REPO_URL="https://github.com/pervezfunctor/linux-config.git"
readonly DOT_DIR="$HOME/.linux-config"
readonly LOG_FILE="${HOME}/.linux-config-setup.log"

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

log() {
  printf "INFO: %s\n" "$*"
  printf "INFO: %s\n" "$*" >>"${LOG_FILE}"
}

die() {
  printf "ERROR: %s\n" "$*" >&2
  printf "ERROR: %s\n" "$*" >>"${LOG_FILE}"
  exit 1
}

system_update() {
  log "Updating system packages"

  if has_cmd dnf; then
    sudo dnf update -y
  elif has_cmd zypper; then
    sudo zypper refresh
    sudo zypper up -y
  elif has_cmd pacman; then
    sudo pacman -Syyu --noconfirm
  elif has_cmd apt; then
    sudo apt update -y
    sudo apt upgrade -y
  elif has_cmd brew; then
    brew update
    brew upgrade
  else
    die "Failed to install packages. No package manager found."
  fi
}

si() {
  log "Installing packages..."

  if has_cmd dnf; then
    sudo dnf install -y "$@"
  elif has_cmd zypper; then
    sudo zypper install --non-interactive --auto-agree-with-licenses "$@"
  elif has_cmd pacman; then
    sudo pacman -S --noconfirm "$@"
  elif has_cmd apt; then
    sudo apt install -y "$@"
  elif has_cmd brew; then
    brew install "$@"
  else
    die "Failed to install packages. No package manager found."
  fi
}

dotfiles_clone() {
  [ -d "$DOT_DIR" ] || {
    echo "Cloning dotfiles to $DOT_DIR."
    git clone "$REPO_URL" "$DOT_DIR" || die "Failed to clone $REPO_URL"
    return
  }

  [ -z "$(git -C "$DOT_DIR" status --porcelain)" ] && {
    echo "Dotfiles repo clean. Pulling latest changes"
    git -C "$DOT_DIR" pull --rebase || {
      echo "Rebase failed. Aborting."
      git -C "$DOT_DIR" rebase --abort || die "Failed to abort rebase"
    }
  }
}

pixi_install() {
  has_cmd pixi && return 0

  echo "Installing pixi..."
  curl -fsSL https://pixi.sh/install.sh | sh
  has_cmd pixi || die "Failed to install pixi"
}

pixi_packages_install() {
  pixi_install

  echo "Installing pixi packages..."
  pixi global install nushell go-gum trash-cli starship gh
  has_cmd nu || die "Failed to install nushell"
}

init_logs() {
  rm -f "${LOG_FILE}"
  touch "${LOG_FILE}"
}

brew_install() {
  has_cmd brew && return 0

  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
}

fresh_install() {
  system_update
  has_cmd git || si git || die "Failed to install git"
  dotfiles_clone

  pixi_packages_install

  "$DOT_DIR/nu/setup-shell.nu" fish 2>&1 | tee -a "${LOG_FILE}"
}

help() {
  echo "Usage: $0 [fresh|brew|shell|desktop]"
  echo "  fresh                 - Perform a fresh install"
  echo "  brew                  - Install Homebrew"
  echo "  shell  options...     - Set up shell configuration"
  echo "  desktop options...    - Set up desktop environment"
}

main() {
  export PATH="$HOME/.pixi/bin:$PATH"
  init_logs

  if [ $# -eq 0 ] || [ "$1" = "fresh" ]; then
    fresh_install
    return 0
  fi

  local opt="$1"
  shift

  if [ "$opt" = "brew" ]; then
    brew_install
  elif [ "$opt" = "shell" ]; then
    "$DOT_DIR/nu/setup-shell.nu" "$@" 2>&1 | tee -a "${LOG_FILE}"
  elif [ "$opt" = "desktop" ]; then
    "$DOT_DIR/nu/setup-desktop.nu" "$@" 2>&1 | tee -a "${LOG_FILE}"
  else
    die "Unknown option: $opt"
  fi
}

main "$@"
