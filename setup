#!/usr/bin/env bash

set -Eeuo pipefail

readonly RAW_BASE_URL="https://raw.githubusercontent.com/pervezfunctor/linux-config/refs/heads/main"

main() {
  command -v curl >/dev/null 2>&1 || {
    echo "setup launcher requires curl for remote bootstrap" >&2
    exit 1
  }

  command -v bun >/dev/null 2>&1 || {
    curl -fsSL https://bun.sh/install | bash
    export PATH="$HOME/.bun/bin:$PATH"
  }

  command -v bun >/dev/null 2>&1 || {
    echo "setup launcher requires bun" >&2
    exit 1
  }

  exec bash -c 'curl -fsSL "$1" | bun run -' bash "${RAW_BASE_URL}/setup.ts" "$@"
}

main "$@"
