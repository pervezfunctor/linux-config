{
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.5.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "name": "linux-config",
  "version": "1.0.0",
  "description": "Setup development workstation with [niri](https://mangowc.vercel.app) or [mangowc](https://mangowc.vercel.app) as your window manager.",
  "main": "src/setup.ts",
  "bin": {
    "linux-config-setup": "./src/setup.ts",
    "linux-config-stow": "./src/stow.ts",
    "linux-config-logs": "./src/view_logs.ts"
  },
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "start": "bun run ./src/setup.ts",
    "setup": "bun run ./src/setup.ts",
    "stow": "bun run ./src/stow.ts",
    "logs": "bun run ./src/view_logs.ts",
    "test": "bun test tests",
    "format": "oxfmt src/*.ts tests/*.ts",
    "lint": "oxlint src/*.ts tests/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pervezfunctor/linux-config.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "bun": ">=1.0.0"
  },
  "bugs": {
    "url": "https://github.com/pervezfunctor/linux-config/issues"
  },
  "homepage": "https://github.com/pervezfunctor/linux-config#readme",
  "dependencies": {
    "zx": "^8.8.5"
  },
  "private": true
}
